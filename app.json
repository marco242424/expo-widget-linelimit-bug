{
  "expo": {
    "name": "expo-widget-linelimit-bug",
    "slug": "expo-widget-linelimit-bug",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marco242424.widgetlinelimitbug"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.marco242424.widgetlinelimitbug"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "LockWidget",
              "displayName": "Line Limit Bug",
              "description": "Reproduces lineLimit(3) only showing 2 lines",
              "supportedFamilies": ["accessoryRectangular"]
            }
          ]
        }
      ]
    ]
  }
}
